{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["principle_id", "statement", "source_claim_ids", "created_at", "version"],
  "properties": {
    "principle_id": { "type": "string", "pattern": "^PRIN-[A-F0-9]{16}$" },
    "statement": { "type": "string", "minLength": 1 },
    "source_claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^CLM-[A-F0-9]{16}$" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "version": { "type": "string", "const": "v5.0" }
  }
}
